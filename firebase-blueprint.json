{
  "entities": {
    "bill": {
      "title": "Bill",
      "description": "An invoice or billing transaction generated by KR Store POS",
      "type": "object",
      "properties": {
        "bill_no": {
          "type": "string",
          "description": "Unique auto-generated bill number"
        },
        "customer_name": {
          "type": "string",
          "description": "Name of the customer"
        },
        "date": {
          "type": "string",
          "description": "Date of transaction (YYYY-MM-DD)"
        },
        "time": {
          "type": "string",
          "description": "Time of transaction (HH:MM:SS)"
        },
        "subtotal": {
          "type": "number",
          "description": "Sum of all items totals before taxes & discounts"
        },
        "gst": {
          "type": "number",
          "description": "Calculated GST tax in currency units"
        },
        "discount": {
          "type": "number",
          "description": "Applied flat or percentage discount value"
        },
        "grand_total": {
          "type": "number",
          "description": "Final payable amount"
        },
        "payment_method": {
          "type": "string",
          "description": "Cash, Card, UPI, or Other"
        },
        "pdf_url": {
          "type": "string",
          "description": "Secure Cloudinary hosting URL of generated receipt PDF"
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        },
        "items": {
          "type": "array",
          "description": "List of items in this purchase"
        }
      },
      "required": ["bill_no", "date", "subtotal", "grand_total"]
    }
  },
  "firestore": {
    "bills/{billId}": {
      "schema": "bill",
      "description": "Collection of all sales bills and invoices"
    }
  }
}
